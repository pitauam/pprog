{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cppbuild",
			"label": "Compilar proyecto de C con tasks.json customizado",
			"command": "/usr/bin/clang-17",
			"args": [
				"-fcolor-diagnostics",
				"-Wall",
				"-ansi",
				"-pedantic",
				"-g",
				"-fansi-escape-codes",
				"${workspaceFolder}/src/*.c",
				"-I",
				"${workspaceFolder}/include",
				"-o",
				"${fileDirname}/${fileBasenameNoExtension}"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build",
			"detail": "compiler: /usr/bin/clang-17"
		}
	]
}
